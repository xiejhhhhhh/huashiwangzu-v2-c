  "watchdog_defaults": {
    "poll_interval": 2.0,
    "launch_timeout": 120,
    "model_load_seconds": 20,
    "auto_unload": true,
    "idle_timeout_seconds": 180,
    "idle_reap_interval_seconds": 30,
    "startup_stall_timeout_seconds": 180,
    "max_startup_seconds": 900
  },
  "providers": {
    "opencode": {
      "type": "opencode",
      "api_url": "https://opencode.ai/zen/go/v1/chat/completions",
      "api_key_env": "DEEPSEEK_API_KEY"
    },
    "gptstore-local": {
      "type": "openai_compat",
      "api_url": "http://127.0.0.1:50936/v1/responses",
      "api_protocol": "responses",
      "api_key_env": "GPTSTORE_LOCAL_API_KEY",
      "provider_name": "gptstore-local",
      "timeout_seconds": 120,
      "description": "本地 Claude Code 内置 GPT-5.5 代理（50936 端口），知识库分析专用，零云费用"
    },
    "gptstore-text": {
      "type": "openai_compat",
      "api_url": "https://jayce.sky1818.com/v1/responses",
      "api_protocol": "responses",
      "api_key_env": "GPTSTORE_API_KEY",
      "provider_name": "gptstore-text",
      "session_affinity": {
        "header": "X-Session-ID",
        "prefix": "knowledge-gptstore",
        "scope": "request"
      },
      "auth_recovery": {
        "strategy": "rotate_session",
        "status_codes": [
          401,
          429,
          502,
          503,
          504
        ],
        "max_attempts": 5,
        "delay_seconds": 0.2,
        "exception_names": [
          "ReadTimeout",
          "ConnectTimeout",
          "TimeoutException",
          "RemoteProtocolError",
          "ConnectError",
          "httpx.ReadTimeout",
          "httpx.ConnectTimeout",
          "httpx.TimeoutException",
          "httpx.RemoteProtocolError",
          "httpx.ConnectError"
        ],
        "timeout_seconds": 90
      },
      "description": "Cloud OpenAI-compatible endpoint for vision and text analysis (via jayce.sky1818.com)"
    },
    "llama": {
      "type": "openai_compat",
      "api_url": "http://127.0.0.1:30003/v1/chat/completions",
      "provider_name": "llama"
    },
    "qwen3-vl-local": {
      "type": "openai_compat",
      "api_url": "http://127.0.0.1:30002/v1/chat/completions",
      "provider_name": "llama"
    },
    "local": {
      "type": "local",
      "provider_name": "local",
      "allow_echo": false,
      "description": "Disabled echo provider for tests only; production local fallback uses llama.cpp or ollama."
    },
    "ollama": {
      "type": "openai_compat",
      "api_url": "http://127.0.0.1:11434/v1/chat/completions",
      "provider_name": "ollama",
      "description": "Local Ollama（仅供向量回填等本地大批量任务使用，Agent链路不走此provider）"
    },
    "mimo": {
      "type": "openai_compat",
      "api_url": "https://token-plan-cn.xiaomimimo.com/v1/chat/completions",
      "api_key_env": "MIMO_GATE1_KEY",
      "provider_name": "mimo",
      "description": "Xiaomi MiMo cloud vision-language model"
    },
    "deepseek-anthropic": {
      "type": "anthropic",
      "api_url": "https://api.deepseek.com/anthropic/v1/messages",
      "api_protocol": "anthropic",
      "api_key_env": "DEEPSEEK_ANTHROPIC_KEY",
      "provider_name": "deepseek-anthropic",
      "timeout_seconds": 120,
