      "type": "anthropic",
      "api_url": "https://jayce.sky1818.com/v1/messages",
      "api_protocol": "anthropic",
      "api_key_env": "JAYCE_CLAUDE_KEY",
      "provider_name": "jayce-claude",
      "proxy": "http://127.0.0.1:4780",
      "timeout_seconds": 120,
