{
  "key": "knowledge",
  "name": "知识库",
  "icon": "Collection",
  "icon_asset": "",
  "category": "AI",
  "module_type": "orchestrator",
  "module_family": "knowledge",
  "product_status": "core",
  "component_key": "index.vue",
  "route_prefix": "/api/knowledge",
  "permissions": [
    "viewer",
    "editor",
    "admin"
  ],
  "sort_order": 200,
  "default_width": 1100,
  "default_height": 700,
  "singleton": true,
  "show_in_launcher": true,
  "show_on_desktop": true,
  "show_in_tray": false,
  "show_in_sidebar": false,
  "window_type": "normal",
  "allow_multiple": false,
  "supported_formats": [],
  "editable_formats": [],
  "creatable_formats": [],
  "module_version": "1.0.0",
  "contract_version": "2.0",
  "permission_declaration": {
    "default": "viewer",
    "actions": [
      {
        "action": "knowledge_view",
        "name": "查看知识库",
        "min_role": "viewer"
      },
      {
        "action": "knowledge_upload",
        "name": "上传资料",
        "min_role": "editor"
      },
      {
        "action": "knowledge_delete",
        "name": "删除资料",
        "min_role": "editor"
      },
      {
        "action": "knowledge_manage",
        "name": "管理知识库",
        "min_role": "admin"
      }
    ]
  },
  "public_actions": [
    {
      "action": "search",
      "description": "按关键词搜索知识库，返回相关块",
      "parameters": {
        "query": {
          "type": "string",
          "description": "搜索关键词"
        },
        "top_k": {
          "type": "integer",
          "description": "返回结果数（默认5）"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "get_block",
      "description": "按 block_id 获取内容块详情",
      "parameters": {
        "block_id": {
          "type": "integer",
          "description": "内容块ID"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "get_page_fusion",
      "description": "获取页级融合内容",
      "parameters": {
        "document_id": {
          "type": "integer",
          "description": "文档ID"
        },
        "page": {
          "type": "integer",
          "description": "页号"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "get_entity_dictionary",
      "description": "查询实体词典",
      "parameters": {
        "keyword": {
          "type": "string",
          "description": "搜索关键词（可选）"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "get_graph_context",
      "description": "查询图谱上下文",
      "parameters": {
        "entity_id": {
          "type": "integer",
          "description": "实体ID"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "get_pending_count",
      "description": "获取待确认数量（治理用）",
      "parameters": {},
      "min_role": "viewer"
    },
    {
      "action": "classify_pipeline_debt",
      "description": "dry-run 分类历史知识库管道债，不修改队列",
      "parameters": {
        "limit": {
          "type": "integer",
          "description": "最多检查的失败任务数（默认500）"
        },
        "category": {
          "type": "string",
          "description": "可选，单个或逗号分隔分类过滤"
        },
        "categories": {
          "type": "array",
          "description": "可选，分类过滤列表"
        },
        "category_limits": {
          "type": "object",
          "description": "可选，按分类限制数量，如 {\"doc_missing\":20}"
        },
        "limit_each": {
          "type": "integer",
          "description": "可选，每个分类默认选取数量"
        },
        "order": {
          "type": "string",
          "description": "候选排序：newest 或 oldest"
        },
        "task_ids": {
          "type": "array",
          "description": "可选，精确 task id 列表；不受 limit_each 影响"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "apply_pipeline_debt",
      "description": "dry-run 或 guarded apply 历史知识库管道债治理动作",
      "parameters": {
        "action": {
          "type": "string",
          "description": "archive_obsolete 或 retry_live"
        },
        "limit": {
          "type": "integer",
          "description": "最多检查的失败任务数（默认500）"
        },
        "task_ids": {
          "type": "array",
          "description": "可选，精确 task id 列表；不受 limit_each 影响"
        },
        "dry_run": {
          "type": "boolean",
          "description": "为 true 时只预览，默认 true"
        },
        "category": {
          "type": "string",
          "description": "可选，单个或逗号分隔分类过滤"
        },
        "categories": {
          "type": "array",
          "description": "可选，分类过滤列表"
        },
        "category_limits": {
          "type": "object",
          "description": "可选，按分类限制数量，如 {\"doc_missing\":20}"
        },
        "limit_each": {
          "type": "integer",
          "description": "可选，每个分类默认选取数量"
        },
        "order": {
          "type": "string",
          "description": "候选排序：newest 或 oldest"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "reconcile_orphan_pipeline_runs",
      "description": "dry-run 或 guarded apply 收口无 task_id 的 orphan running 诊断运行",
      "parameters": {
        "limit": {
          "type": "integer",
          "description": "最多检查的 orphan run 数（默认500）"
        },
        "run_ids": {
          "type": "array",
          "description": "可选，限定 run id 列表"
        },
        "dry_run": {
          "type": "boolean",
          "description": "为 true 时只预览，默认 true"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "reconcile_pending_pipeline_queue",
      "description": "dry-run 或归档已不可执行的 pending 知识库管道队列任务，保留仍可执行的 live pending",
      "parameters": {
        "limit": {
          "type": "integer",
          "description": "最多检查的 pending 任务数（默认500）"
        },
        "task_ids": {
          "type": "array",
          "description": "可选，精确 task id 列表；不受分类限制影响"
        },
        "dry_run": {
          "type": "boolean",
          "description": "为 true 时只预览，默认 true"
        },
        "category": {
          "type": "string",
          "description": "可选，单个或逗号分隔分类过滤"
        },
        "categories": {
          "type": "array",
          "description": "可选，分类过滤列表"
        },
        "category_limits": {
          "type": "object",
          "description": "可选，按分类限制数量"
        },
        "limit_each": {
          "type": "integer",
          "description": "可选，每个分类默认选取数量"
        },
        "order": {
          "type": "string",
          "description": "候选排序：newest 或 oldest"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "reconcile_running_pipeline_queue",
      "description": "dry-run 或恢复中断的 running 知识库管道队列任务，live 任务回 pending，obsolete 任务归档 skipped",
      "parameters": {
        "limit": {
          "type": "integer",
          "description": "最多检查的 running 任务数（默认500）"
        },
        "task_ids": {
          "type": "array",
          "description": "可选，精确 task id 列表；不受分类限制影响"
        },
        "dry_run": {
          "type": "boolean",
          "description": "为 true 时只预览，默认 true"
        },
        "category": {
          "type": "string",
          "description": "可选，单个或逗号分隔分类过滤"
        },
        "categories": {
          "type": "array",
          "description": "可选，分类过滤列表"
        },
        "category_limits": {
          "type": "object",
          "description": "可选，按分类限制数量"
        },
        "limit_each": {
          "type": "integer",
          "description": "可选，每个分类默认选取数量"
        },
        "order": {
          "type": "string",
          "description": "候选排序：newest 或 oldest"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "audit_lifecycle_debt",
      "description": "审计源文件已删除、缺失、路径异常或磁盘文件缺失的 active 知识库文档",
      "parameters": {
        "limit": {
          "type": "integer",
          "description": "最多返回候选文档数（默认500）"
        },
        "reason": {
          "type": "string",
          "description": "source_file_deleted、source_file_missing、source_storage_path_missing、source_path_unsafe、source_file_physical_missing 或 source_unavailable"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "archive_source_unavailable_documents",
      "description": "dry-run 或确认归档源文件不可用的知识库文档",
      "parameters": {
        "dry_run": {
          "type": "boolean",
          "description": "为 true 时只预览，默认 true"
        },
        "limit": {
          "type": "integer",
          "description": "最多归档文档数（默认100）"
        },
        "reason": {
          "type": "string",
          "description": "source_file_deleted、source_file_missing、source_storage_path_missing、source_path_unsafe、source_file_physical_missing 或 source_unavailable"
        },
        "confirm": {
          "type": "string",
          "description": "真实执行必须为 ARCHIVE_SOURCE_UNAVAILABLE"
        },
        "audit_reason": {
          "type": "string",
          "description": "治理原因说明"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "get_evidence_detail",
      "description": "获取证据详情",
      "parameters": {
        "entity_id": {
          "type": "integer",
          "description": "实体ID"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "plan_pipeline_rerun",
      "description": "dry-run 规划知识库管道重跑，不修改队列或产物",
      "parameters": {
        "document_id": {
          "type": "integer",
          "description": "文档ID"
        },
        "reason": {
          "type": "string",
          "description": "prompt_changed/schema_changed/model_changed/source_changed/vlm_preprocess_changed/manual_failed_retry"
        },
        "stage": {
          "type": "string",
          "description": "可选起始阶段：raw/fusion/profile/graph/relations"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "backfill_cognitive_v3",
      "description": "回填知识库 V3 内容复用链路、批次验收报告和可选认知派生索引",
      "parameters": {
        "dry_run": {
          "type": "boolean",
          "description": "为 true 时只预览，默认 true"
        },
        "limit": {
          "type": "integer",
          "description": "最多检查文件数（默认1000）"
        },
        "source_root": {
          "type": "string",
          "description": "可选导入来源标签，写入批次报告"
        },
        "build_terms": {
          "type": "boolean",
          "description": "真实执行时是否构建词项/事实/因果派生索引"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "derive_cognitive_index",
      "description": "按单文档重建 V3 词项、事实和因果候选派生索引",
      "parameters": {
        "document_id": {
          "type": "integer",
          "description": "文档ID"
        },
        "limit": {
          "type": "integer",
          "description": "每段来源文本最多提取词项数（默认200）"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "enqueue_incomplete_documents",
      "description": "预览或补排未完成深层知识分析的文档",
      "parameters": {
        "dry_run": {
          "type": "boolean",
          "description": "为 true 时只预览，默认 true"
        },
        "limit": {
          "type": "integer",
          "description": "最多检查/补排文档数（默认20）"
        },
        "extensions": {
          "type": "array",
          "description": "可选扩展名过滤，如 [pdf, docx, jpg]"
        },
        "priority": {
          "type": "integer",
          "description": "新队列任务优先级，默认5"
        },
        "include_search_incomplete": {
          "type": "boolean",
          "description": "是否包含解析/向量/raw/fusion 未完成的文档，默认 true"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "import_enterprise_source_batch",
      "description": "dry-run 或限量导入企业源目录文件并触发知识库分析",
      "parameters": {
        "source_root": {
          "type": "string",
          "description": "本地源目录"
        },
        "target_root_name": {
          "type": "string",
          "description": "目标根目录名，默认 企业微盘导入"
        },
        "dry_run": {
          "type": "boolean",
          "description": "为 true 时只预览，默认 true"
        },
        "limit": {
          "type": "integer",
          "description": "最多导入文件数（默认20，最高200）"
        },
        "extensions": {
          "type": "array",
          "description": "可选扩展名过滤"
        },
        "skip_existing_md5": {
          "type": "boolean",
          "description": "是否跳过当前用户已存在 md5，默认 true"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "get_ocr_words",
      "description": "获取 PDF OCR 词坐标",
      "parameters": {
        "file_id": {
          "type": "integer",
          "description": "文件ID"
        },
        "page": {
          "type": "integer",
          "description": "页号"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "ingest",
      "description": "将文件注册到知识库并触发分析",
      "parameters": {
        "file_id": {
          "type": "integer",
          "description": "文件ID"
        }
      },
      "min_role": "editor"
    },
    {
      "action": "get_ingest_status",
      "description": "查询文档入库任务与分析阶段状态",
      "parameters": {
        "document_id": {
          "type": "integer",
          "description": "文档ID"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "export",
      "description": "导出已解析文档（markdown/html/json）",
      "parameters": {
        "document_id": {
          "type": "integer",
          "description": "文档ID"
        },
        "format": {
          "type": "string",
          "description": "导出格式：markdown/html/json",
          "default": "markdown"
        }
      },
      "min_role": "viewer"
    }
  ],
  "dependency_declaration": [
    {
      "module": "pdf-parser",
      "optional": false
    },
    {
      "module": "docx-parser",
      "optional": false
    },
    {
      "module": "pptx-parser",
      "optional": false
    },
    {
      "module": "xlsx-parser",
      "optional": false
    },
    {
      "module": "text-parser",
      "optional": false
    },
    {
      "module": "image-vision",
      "optional": true
    }
  ],
  "event_handler_declaration": [
    {
      "event": "file.uploaded",
      "handler": "on_file_uploaded",
      "description": "文件上传后自动登记到知识库并触发分析"
    },
    {
      "event": "file.deleted",
      "handler": "file_lifecycle_service",
      "description": "源文件进入回收站后标记知识文档源不可用"
    },
    {
      "event": "file.restored",
      "handler": "file_lifecycle_service",
      "description": "源文件恢复后恢复或重新入队知识文档"
    }
  ],
  "db_migration_declaration": [],
  "backend": {
    "enabled": true,
    "router": "backend/router.py"
  }
}
