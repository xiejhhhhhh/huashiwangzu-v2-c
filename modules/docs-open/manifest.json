{
  "key": "docs-open",
  "name": "文档开放接口",
  "icon": "DocumentCopy",
  "icon_asset": "",
  "category": "tools",
  "module_type": "app",
  "module_family": "office",
  "product_status": "active",
  "component_key": "index.vue",
  "route_prefix": "/api/docs",
  "permissions": [
    "viewer",
    "editor",
    "admin"
  ],
  "sort_order": 180,
  "default_width": 800,
  "default_height": 600,
  "singleton": true,
  "show_in_launcher": true,
  "show_on_desktop": false,
  "show_in_tray": false,
  "show_in_sidebar": false,
  "window_type": "normal",
  "allow_multiple": false,
  "supported_formats": [],
  "editable_formats": [],
  "creatable_formats": [],
  "module_version": "1.0.0",
  "contract_version": "2.0",
  "backend": {
    "enabled": true,
    "router": "backend/router.py"
  },
  "public_actions": [
    {
      "action": "open",
      "description": "Open a document by file_id, returns embed_url and content info",
      "parameters": {
        "file_id": {
          "type": "int"
        },
        "mode": {
          "type": "string",
          "enum": [
            "view",
            "edit"
          ]
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "get_content",
      "description": "Get structured JSON content of a document",
      "parameters": {
        "file_id": {
          "type": "int"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "create_doc",
      "description": "Create a new empty document",
      "parameters": {
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "txt",
            "md",
            "json",
            "yaml",
            "yml",
            "xml",
            "ini",
            "cfg",
            "log",
            "csv",
            "docx",
            "xlsx",
            "pptx",
            "pdf"
          ]
        }
      },
      "min_role": "editor"
    }
  ]
}
