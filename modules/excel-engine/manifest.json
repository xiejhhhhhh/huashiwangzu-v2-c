{
  "key": "excel-engine",
  "name": "Excel 编辑器",
  "icon": "Grid",
  "icon_asset": "",
  "category": "file-editor",
  "module_type": "editor",
  "module_family": "office",
  "product_status": "active",
  "component_key": "index.vue",
  "route_prefix": null,
  "permissions": [
    "viewer",
    "editor",
    "admin"
  ],
  "sort_order": 10,
  "default_width": 1100,
  "default_height": 700,
  "min_width": 800,
  "min_height": 500,
  "singleton": false,
  "show_in_launcher": true,
  "show_on_desktop": false,
  "show_in_tray": false,
  "show_in_sidebar": false,
  "window_type": "normal",
  "allow_multiple": true,
  "supported_formats": [
    "xlsx",
    "xls",
    "csv"
  ],
  "editable_formats": [
    "xlsx",
    "csv"
  ],
  "creatable_formats": [
    {
      "extension": "xlsx",
      "label": "Excel 工作簿",
      "mime_type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    },
    {
      "extension": "csv",
      "label": "CSV 文件",
      "mime_type": "text/csv"
    }
  ],
  "module_version": "1.0.0",
  "contract_version": "2.0",
  "backend": {
    "enabled": true,
    "router": "backend/router.py"
  },
  "public_actions": [
    {
      "action": "parse",
      "description": "Parse XLSX/CSV files into cell data",
      "parameters": {
        "file_id": {
          "type": "int"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "create_workbook",
      "description": "Create a new empty workbook in the database",
      "parameters": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Workbook name",
            "default": "Untitled"
          },
          "state_key": {
            "type": "string",
            "description": "Optional state_key (auto-generated if omitted)"
          }
        }
      },
      "min_role": "editor"
    },
    {
      "action": "import_file_to_workbook",
      "description": "Import a file into a database workbook for editing",
      "parameters": {
        "type": "object",
        "properties": {
          "file_id": {
            "type": "integer",
            "description": "File ID to import"
          },
          "state_key": {
            "type": "string",
            "description": "Optional state_key"
          }
        },
        "required": [
          "file_id"
        ]
      },
      "min_role": "editor"
    },
    {
      "action": "update_range",
      "description": "Update a range of cells",
      "parameters": {
        "type": "object",
        "properties": {
          "state_key": {
            "type": "string",
            "description": "Workbook state_key"
          },
          "sheet": {
            "type": "string",
            "description": "Sheet name",
            "default": "Sheet1"
          },
          "start_row": {
            "type": "integer",
            "description": "Starting row (0-based)",
            "default": 0
          },
          "start_col": {
            "type": "integer",
            "description": "Starting column (0-based)",
            "default": 0
          },
          "rows": {
            "type": "array",
            "description": "2D array of cell values"
          }
        },
        "required": [
          "state_key",
          "rows"
        ]
      },
      "min_role": "editor"
    },
    {
      "action": "append_rows",
      "description": "Append rows to the end of a sheet",
      "parameters": {
        "type": "object",
        "properties": {
          "state_key": {
            "type": "string",
            "description": "Workbook state_key"
          },
          "sheet": {
            "type": "string",
            "description": "Sheet name",
            "default": "Sheet1"
          },
          "rows": {
            "type": "array",
            "description": "2D array of cell values to append"
          }
        },
        "required": [
          "state_key",
          "rows"
        ]
      },
      "min_role": "editor"
    },
    {
      "action": "undo",
      "description": "Undo the last operation",
      "parameters": {
        "type": "object",
        "properties": {
          "state_key": {
            "type": "string",
            "description": "Workbook state_key"
          }
        },
        "required": [
          "state_key"
        ]
      },
      "min_role": "editor"
    },
    {
      "action": "redo",
      "description": "Redo the last undone operation",
      "parameters": {
        "type": "object",
        "properties": {
          "state_key": {
            "type": "string",
            "description": "Workbook state_key"
          }
        },
        "required": [
          "state_key"
        ]
      },
      "min_role": "editor"
    },
    {
      "action": "list_history",
      "description": "List operation history for a workbook",
      "parameters": {
        "type": "object",
        "properties": {
          "state_key": {
            "type": "string",
            "description": "Workbook state_key"
          }
        },
        "required": [
          "state_key"
        ]
      },
      "min_role": "viewer"
    },
    {
      "action": "list_versions",
      "description": "List saved versions of a workbook",
      "parameters": {
        "type": "object",
        "properties": {
          "state_key": {
            "type": "string",
            "description": "Workbook state_key"
          }
        },
        "required": [
          "state_key"
        ]
      },
      "min_role": "viewer"
    },
    {
      "action": "restore_version",
      "description": "Restore a workbook to a saved version",
      "parameters": {
        "type": "object",
        "properties": {
          "state_key": {
            "type": "string",
            "description": "Workbook state_key"
          },
          "version_id": {
            "type": "integer",
            "description": "Version ID to restore"
          }
        },
        "required": [
          "state_key",
          "version_id"
        ]
      },
      "min_role": "editor"
    },
    {
      "action": "export_xlsx",
      "description": "Export workbook to XLSX file",
      "parameters": {
        "type": "object",
        "properties": {
          "state_key": {
            "type": "string",
            "description": "Workbook state_key"
          },
          "sheet": {
            "type": "string",
            "description": "Sheet name",
            "default": "Sheet1"
          },
          "folder_id": {
            "type": "integer",
            "description": "Target folder ID (optional)"
          }
        },
        "required": [
          "state_key"
        ]
      },
      "min_role": "editor"
    },
    {
      "action": "compile_xlsx",
      "description": "Compile workbook to temporary XLSX for download without creating a file record",
      "parameters": {
        "type": "object",
        "properties": {
          "state_key": {
            "type": "string",
            "description": "Workbook state_key"
          },
          "sheet": {
            "type": "string",
            "description": "Sheet name",
            "default": "Sheet1"
          }
        },
        "required": [
          "state_key"
        ]
      },
      "min_role": "viewer"
    },
    {
      "action": "publish_to_desktop",
      "description": "Publish workbook to desktop",
      "parameters": {
        "type": "object",
        "properties": {
          "state_key": {
            "type": "string",
            "description": "Workbook state_key"
          },
          "sheet": {
            "type": "string",
            "description": "Sheet name",
            "default": "Sheet1"
          },
          "target_file_id": {
            "type": "integer",
            "description": "Target desktop file ID (optional, creates new if omitted)"
          },
          "folder_id": {
            "type": "integer",
            "description": "Target folder ID (optional)"
          }
        },
        "required": [
          "state_key"
        ]
      },
      "min_role": "editor"
    }
  ]
}
