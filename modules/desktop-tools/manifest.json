{
  "key": "desktop-tools",
  "name": "Desktop Tools",
  "icon": "List",
  "icon_asset": "",
  "category": "tools",
  "component_key": "",
  "route_prefix": "/api/desktop-tools",
  "permissions": [
    "viewer",
    "editor",
    "admin"
  ],
  "sort_order": 200,
  "default_width": 800,
  "default_height": 600,
  "singleton": true,
  "show_in_launcher": false,
  "show_on_desktop": false,
  "show_in_tray": false,
  "show_in_sidebar": false,
  "window_type": "background-service",
  "allow_multiple": false,
  "supported_formats": [],
  "editable_formats": [],
  "creatable_formats": [],
  "module_version": "1.0.0",
  "contract_version": "2.0",
  "public_actions": [
    {
      "action": "list_files",
      "description": "List files in a folder (or root). Returns file name, type, size, and id.",
      "parameters": {
        "type": "object",
        "properties": {
          "folder_id": {
            "type": "integer",
            "description": "Folder ID (0 or omit for root)"
          },
          "page": {
            "type": "integer",
            "description": "Page number"
          },
          "page_size": {
            "type": "integer",
            "description": "Items per page (max 100)"
          }
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "search_files",
      "description": "Search files by keyword and/or extension. Returns matching file metadata.",
      "parameters": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "Search keyword"
          },
          "extension": {
            "type": "string",
            "description": "Filter by extension"
          },
          "page": {
            "type": "integer",
            "description": "Page number"
          },
          "page_size": {
            "type": "integer",
            "description": "Items per page (max 100)"
          }
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "read_file",
      "description": "Read file content by file_id. Routes to format parsers (PDF, DOCX, XLSX, etc.) and returns text content capped at 20000 chars with truncation metadata.",
      "parameters": {
        "type": "object",
        "properties": {
          "file_id": {
            "type": "integer",
            "description": "File ID in the file storage system"
          }
        },
        "required": [
          "file_id"
        ]
      },
      "min_role": "viewer"
    },
    {
      "action": "list_apps",
      "description": "List desktop applications available to the current user.",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "min_role": "viewer"
    },
    {
      "action": "get_file",
      "description": "Get a single file's metadata by file_id.",
      "parameters": {
        "type": "object",
        "properties": {
          "file_id": {"type": "integer", "description": "File ID"}
        },
        "required": ["file_id"]
      },
      "min_role": "viewer"
    },
    {
      "action": "create_file",
      "description": "Create a new file with text content.",
      "parameters": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "description": "File name"},
          "extension": {"type": "string", "description": "File extension"},
          "content": {"type": "string", "description": "File content"},
          "folder_id": {"type": "integer", "description": "Target folder ID"}
        },
        "required": ["name", "extension"]
      },
      "min_role": "editor"
    },
    {
      "action": "replace_file",
      "description": "Replace file content from text, artifact, or another file. No base64 needed.",
      "parameters": {
        "type": "object",
        "properties": {
          "old_file_id": {"type": "integer", "description": "Existing file ID to replace"},
          "new_content": {"type": "string", "description": "New content as text"},
          "source_artifact_id": {"type": "integer", "description": "Source artifact ID"},
          "source_file_id": {"type": "integer", "description": "Source file ID"}
        },
        "required": ["old_file_id"]
      },
      "min_role": "editor"
    },
    {
      "action": "delete_file",
      "description": "Soft-delete a file.",
      "parameters": {
        "type": "object",
        "properties": {
          "file_id": {"type": "integer", "description": "File ID"}
        },
        "required": ["file_id"]
      },
      "min_role": "editor"
    },
    {
      "action": "rename_file",
      "description": "Rename a file.",
      "parameters": {
        "type": "object",
        "properties": {
          "file_id": {"type": "integer", "description": "File ID"},
          "new_name": {"type": "string", "description": "New file name"}
        },
        "required": ["file_id", "new_name"]
      },
      "min_role": "editor"
    },
    {
      "action": "copy_file",
      "description": "Copy a file.",
      "parameters": {
        "type": "object",
        "properties": {
          "file_id": {"type": "integer", "description": "File ID"},
          "target_folder_id": {"type": "integer", "description": "Target folder ID"}
        },
        "required": ["file_id"]
      },
      "min_role": "editor"
    },
    {
      "action": "list_versions",
      "description": "List file versions (via artifact).",
      "parameters": {
        "type": "object",
        "properties": {
          "artifact_id": {"type": "integer", "description": "Artifact ID"}
        },
        "required": ["artifact_id"]
      },
      "min_role": "viewer"
    },
    {
      "action": "restore_version",
      "description": "Restore a file to a previous version.",
      "parameters": {
        "type": "object",
        "properties": {
          "artifact_id": {"type": "integer", "description": "Artifact ID"},
          "version_id": {"type": "integer", "description": "Version ID"}
        },
        "required": ["artifact_id", "version_id"]
      },
      "min_role": "editor"
    },
    {
      "action": "replace_file_from_artifact",
      "description": "Replace a desktop file using content from an artifact. No base64 needed.",
      "parameters": {
        "type": "object",
        "properties": {
          "target_file_id": {"type": "integer", "description": "Desktop file ID"},
          "source_artifact_id": {"type": "integer", "description": "Artifact ID"}
        },
        "required": ["target_file_id", "source_artifact_id"]
      },
      "min_role": "editor"
    },
    {
      "action": "publish_artifact",
      "description": "Publish an artifact to the desktop as a file.",
      "parameters": {
        "type": "object",
        "properties": {
          "artifact_id": {"type": "integer", "description": "Artifact ID"},
          "target_file_id": {"type": "integer", "description": "Target file ID (optional)"}
        },
        "required": ["artifact_id"]
      },
      "min_role": "editor"
    },
    {
      "action": "refresh",
      "description": "Trigger desktop file list refresh.",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "min_role": "viewer"
    }
  ],
  "permission_declaration": {
    "default": "viewer",
    "actions": []
  },
  "dependency_declaration": [],
  "event_handler_declaration": [],
  "db_migration_declaration": [],
  "backend": {
    "enabled": true,
    "router": "backend/router.py"
  }
}
