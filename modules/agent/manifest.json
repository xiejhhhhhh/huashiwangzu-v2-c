{
  "key": "agent",
  "name": "AI 助手",
  "icon": "ChatDotRound",
  "icon_asset": "",
  "category": "AI",
  "component_key": "index.vue",
  "route_prefix": "/api/agent",
  "permissions": ["viewer", "editor", "admin"],
  "sort_order": 100,
  "default_width": 900,
  "default_height": 650,
  "singleton": true,
  "show_in_launcher": true,
  "show_on_desktop": true,
  "show_in_tray": true,
  "show_in_sidebar": false,
  "window_type": "normal",
  "allow_multiple": false,
  "supported_formats": [],
  "editable_formats": [],
  "creatable_formats": [],
  "module_version": "1.0.0",
  "contract_version": "2.0",
  "permission_declaration": {
    "default": "viewer",
    "actions": [
      {"action": "agent_view", "name": "查看AI助手", "min_role": "viewer"},
      {"action": "agent_chat", "name": "发起对话", "min_role": "viewer"},
      {"action": "agent_manage", "name": "管理设置", "min_role": "admin"}
    ]
  },
  "public_actions": [
    {"action": "get_system_prompt", "description": "获取系统提示词", "parameters": {}, "min_role": "admin"},
    {"action": "update_system_prompt", "description": "更新系统提示词", "parameters": {"content": {"type": "string", "description": "提示词内容"}}, "min_role": "admin"},
    {"action": "get_enterprise_prompt", "description": "获取企业提示词", "parameters": {}, "min_role": "admin"},
    {"action": "update_enterprise_prompt", "description": "更新企业提示词", "parameters": {"content": {"type": "string", "description": "提示词内容"}}, "min_role": "admin"},
    {"action": "get_my_profile", "description": "获取个人用户画像", "parameters": {}, "min_role": "viewer"},
    {"action": "update_my_profile", "description": "更新个人用户画像", "parameters": {"profile_data": {"type": "object", "description": "画像数据", "properties": {"tone": {"type": "string"}, "taboos": {"type": "array", "items": {"type": "string"}}, "focus": {"type": "array", "items": {"type": "string"}}, "habits": {"type": "array", "items": {"type": "string"}}}}}, "min_role": "viewer"},
    {"action": "spawn_subagent", "description": "生成子 Agent 执行独立任务", "parameters": {"task": {"type": "string", "description": "任务描述"}}, "min_role": "viewer"}
  ],
  "dependency_declaration": [{"module": "knowledge", "optional": true}],
  "event_handler_declaration": [],
  "db_migration_declaration": [],
  "backend": {"enabled": true, "router": "backend/router.py"}
