{
  "key": "memory",
  "name": "记忆",
  "icon": "Collection",
  "icon_asset": "",
  "category": "tools",
  "module_type": "service",
  "module_family": "agent",
  "product_status": "background",
  "component_key": "index.vue",
  "route_prefix": "/api/memory",
  "permissions": [
    "viewer",
    "editor",
    "admin"
  ],
  "sort_order": 130,
  "default_width": 700,
  "default_height": 500,
  "singleton": true,
  "show_in_launcher": false,
  "show_on_desktop": false,
  "show_in_tray": false,
  "show_in_sidebar": false,
  "window_type": "normal",
  "allow_multiple": false,
  "supported_formats": [],
  "editable_formats": [],
  "creatable_formats": [],
  "public_actions": [
    {
      "action": "save",
      "description": "保存一段记忆（事实/偏好/约定），自动提取摘要和向量用于语义检索",
      "parameters": {
        "text": {
          "type": "string",
          "description": "记忆文本"
        },
        "tags": {
          "type": "string",
          "description": "标签"
        },
        "source": {
          "type": "string",
          "description": "来源（可选，如 auto-distill/user-save）"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "recall",
      "description": "语义检索自己的记忆（向量语义召回 + 重排 + 可选顺链扩展），不再仅靠关键词",
      "parameters": {
        "query": {
          "type": "string",
          "description": "检索查询（语义匹配）"
        },
        "limit": {
          "type": "integer",
          "description": "返回条数上限"
        },
        "expand_chain": {
          "type": "boolean",
          "description": "是否顺链扩展"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "list",
      "description": "列出自己所有的记忆",
      "parameters": {
        "limit": {
          "type": "integer",
          "description": "返回条数上限"
        },
        "offset": {
          "type": "integer",
          "description": "偏移量"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "delete",
      "description": "删除一条记忆",
      "parameters": {
        "id": {
          "type": "integer",
          "description": "记忆ID"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "fuse",
      "description": "将多条记忆融合成贴合查询的一段简报（即时融合，on-demand）",
      "parameters": {
        "query": {
          "type": "string",
          "description": "查询上下文"
        },
        "ids": {
          "type": "array",
          "description": "记忆ID列表"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "rethink",
      "description": "整条重写一条记忆（自编辑工具，如用户纠正错误时）",
      "parameters": {
        "id": {
          "type": "integer",
          "description": "记忆ID"
        },
        "text": {
          "type": "string",
          "description": "新的完整内容"
        },
        "tags": {
          "type": "string",
          "description": "新标签（可选）"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "replace",
      "description": "替换记忆中的某段文本（精确片段替换）",
      "parameters": {
        "id": {
          "type": "integer",
          "description": "记忆ID"
        },
        "old_text": {
          "type": "string",
          "description": "要替换的旧文本"
        },
        "new_text": {
          "type": "string",
          "description": "新文本"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "insert",
      "description": "向已有记忆追加内容",
      "parameters": {
        "id": {
          "type": "integer",
          "description": "记忆ID"
        },
        "text": {
          "type": "string",
          "description": "追加的内容"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "dream",
      "description": "触发记忆自优化（去重合并 + 建链 + 衰减），后台运行不阻塞",
      "parameters": {},
      "min_role": "editor"
    },
    {
      "action": "save_experience",
      "description": "保存一条成功经验（包含触发条件、有序步骤、工具列表），自动向量化并去重",
      "parameters": {
        "trigger_condition": {
          "type": "string",
          "description": "触发条件（自然语言描述）"
        },
        "steps": {
          "type": "string",
          "description": "JSON 有序步骤"
        },
        "tools_used": {
          "type": "string",
          "description": "JSON 工具列表（可选）"
        },
        "source_conversation_id": {
          "type": "integer",
          "description": "来源对话 ID（可选）"
        },
        "scope": {
          "type": "string",
          "description": "经验范围：user/team/global"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "match_experience",
      "description": "语义匹配当前用户输入相关的成功经验（纯语义，零硬编码规则）",
      "parameters": {
        "query": {
          "type": "string",
          "description": "当前用户输入（语义匹配）"
        },
        "limit": {
          "type": "integer",
          "description": "返回条数上限"
        },
        "team_owner_ids": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "系统通路可传的团队 owner id 列表"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "experience_feedback",
      "description": "反馈经验执行结果：成功则权重 +1，失败则失败次数 +1 并记录注释",
      "parameters": {
        "experience_id": {
          "type": "integer",
          "description": "经验ID"
        },
        "success": {
          "type": "boolean",
          "description": "是否成功"
        },
        "note": {
          "type": "string",
          "description": "失败时的备注（可选）"
        },
        "team_owner_ids": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "系统通路可传的团队 owner id 列表"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "overview_stats",
      "description": "Admin overview: aggregated memory & experience statistics (total_count, with_embedding, avg_confidence, link_count, experience counts, etc.)",
      "parameters": {},
      "min_role": "admin"
    },
    {
      "action": "backfill_embeddings",
      "description": "Admin governance: safely backfill missing memory record embeddings with dry-run, owner, limit, and optional dream linking",
      "parameters": {
        "dry_run": {
          "type": "boolean",
          "description": "仅诊断不写入，默认 true"
        },
        "limit": {
          "type": "integer",
          "description": "本次最多处理条数，1-100，默认 20"
        },
        "owner_id": {
          "type": "integer",
          "description": "只治理指定 owner 的记忆，可选"
        },
        "owner": {
          "type": "integer",
          "description": "owner_id 的兼容别名，可选"
        },
        "run_dream": {
          "type": "boolean",
          "description": "成功回填后触发 dream 建链，可选"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "backfill_links",
      "description": "Admin governance: backfill missing memory_links between existing memory records using vector similarity. Dry-run safe.",
      "parameters": {
        "dry_run": {
          "type": "boolean",
          "description": "仅诊断不写入，默认 true"
        },
        "limit": {
          "type": "integer",
          "description": "本次最多处理条数，1-500，默认 50"
        },
        "owner_id": {
          "type": "integer",
          "description": "只治理指定 owner 的记忆，可选"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "backfill_chunk_embeddings",
      "description": "Admin governance: safely backfill missing memory_chunk embeddings with dry-run support",
      "parameters": {
        "dry_run": {
          "type": "boolean",
          "description": "仅诊断不写入，默认 true"
        },
        "limit": {
          "type": "integer",
          "description": "本次最多处理条数，1-100，默认 20"
        },
        "owner_id": {
          "type": "integer",
          "description": "只治理指定 owner 的 chunk，可选"
        }
      },
      "min_role": "admin"
    },
    {
      "action": "recall_stable_rules",
      "description": "获取当前用户所有活跃的稳定规则记忆（项目边界、用户偏好、硬约束等），按优先级降序返回",
      "parameters": {
        "rule_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "按类型过滤（可选）"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "recall_chunk",
      "description": "语义检索 chunk 级记忆（带 provenance 溯源信息），返回最小粒度段落",
      "parameters": {
        "query": {
          "type": "string",
          "description": "检索查询（语义匹配）"
        },
        "limit": {
          "type": "integer",
          "description": "返回条数上限"
        }
      },
      "min_role": "viewer"
    },
    {
      "action": "save_stable_rule",
      "description": "保存一条稳定规则记忆（项目边界/用户偏好/硬约束/长期规则），不参与向量衰减",
      "parameters": {
        "rule_type": {
          "type": "string",
          "description": "规则类型"
        },
        "content": {
          "type": "string",
          "description": "规则内容"
        },
        "priority": {
          "type": "integer",
          "description": "优先级"
        },
        "source": {
          "type": "string",
          "description": "规则来源（可选）"
        }
      },
      "min_role": "viewer"
    }
  ],
  "module_version": "1.0.0",
  "contract_version": "2.0",
  "backend": {
    "enabled": true,
    "router": "backend/router.py"
  }
}
